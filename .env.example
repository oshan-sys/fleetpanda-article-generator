# Required: your Groq API key (free). Get one at https://console.groq.com/keys
# Never commit the real key — this file is just a template.
GROQ_API_KEY=gsk_your-key-here

# Optional: only needed if you switch app/api/generate/route.ts back to
# Anthropic's Claude API. Not used while GROQ_API_KEY is active.
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Google sign-in (required) ---
# Random secret used to encrypt session cookies. Generate your own with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=replace-with-a-random-generated-secret

# From Google Cloud Console → APIs & Services → Credentials → OAuth client ID.
# See the setup steps shared separately for exact configuration.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
